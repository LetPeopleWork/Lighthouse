{
	"DetailedErrors": true,
	"Serilog": {
		"MinimumLevel": {
			"Default": "Debug",
			"Override": {
				"Microsoft.AspNetCore": "Warning",
				"Microsoft.EntityFrameworkCore": "Warning",
				"Microsoft.AspNetCore.Routing": "Warning",
				"Microsoft.AspNetCore.Hosting": "Warning"
			}
		},
		"WriteTo": [
			{
				"Name": "File",
				"Args": {
					"path": "./logs/log-.txt",
					"rollingInterval": "Day"
				}
			}
		]
	},
	"Database_Postgres": {
		"Provider": "postgres",
		"ConnectionString": "Host=localhost;Port=1886;Database=lighthouse;Username=postgres;Password=postgres",
		"DockerCommand": "docker run --name postgres -e POSTGRES_DB=lighthouse -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -p 1886:5432 -d postgres:17.2-alpine"
	},
	"Kestrel": {
		"Endpoints": {
			"Http": {
				"Url": "http://*:5169"
			},
			"Https": {
				"Url": "https://*:7246"
			}
		}
	},
	"Auth0_Authentication": {
		"Enabled": true,
		"Authority": "https://{your-auth0-domain}.auth0.com",
		"ClientId": "{client-id}",
		"ClientSecret": "{client-secret}",
		"CallbackPath": "/api/auth/callback",
		"SignedOutCallbackPath": "/api/auth/signout-callback",
		"Scopes": ["openid", "profile", "email"],
		"AllowedOrigins": ["https://your-app.example.com"],
		"SessionLifetimeMinutes": 480
	},
	"Google_Authentication": {
		"Enabled": true,
		"Authority": "https://accounts.google.com",
		"ClientId": "{your-client-id}.apps.googleusercontent.com",
		"ClientSecret": "{your-client-secret}",
		"CallbackPath": "/api/auth/callback",
		"SignedOutCallbackPath": "/api/auth/signout-callback",
		"Scopes": ["openid", "profile", "email"],
		"AllowedOrigins": ["https://your-app.example.com"],
		"SessionLifetimeMinutes": 480
	},
	"MicrosoftEntra_Authentication": {
		"Enabled": true,
		"Authority": "https://login.microsoftonline.com/{tenant-id}/v2.0",
		"ClientId": "{application-client-id}",
		"ClientSecret": "{client-secret-value}",
		"CallbackPath": "/api/auth/callback",
		"SignedOutCallbackPath": "/api/auth/signout-callback",
		"Scopes": ["openid", "profile", "email"],
		"AllowedOrigins": ["https://your-app.example.com"],
		"SessionLifetimeMinutes": 480
	},
	"Keycloak_Authentication": {
		"Docker_Command": "docker run -d --name keycloak-lighthouse -p 38080:8080 -e KEYCLOAK_ADMIN=admin -e KEYCLOAK_ADMIN_PASSWORD=admin -v keycloak-lighthouse-data:/opt/keycloak/data quay.io/keycloak/keycloak:latest start-dev",
		"Enabled": true,
		"Authority": "http://localhost:38080/realms/lighthouse",
		"ClientId": "lighthouse-app",
		"ClientSecret": "Bl8WOni0bdYISgVgVpDArFVZfXR9HSZ9",
		"CallbackPath": "/api/auth/callback",
		"SignedOutCallbackPath": "/api/auth/signout-callback",
		"Scopes": ["openid", "profile", "email"],
		"AllowedOrigins": ["http://localhost:5173"],
		"SessionLifetimeMinutes": 480,
		"RequireHttpsMetadata": false
	}
}
