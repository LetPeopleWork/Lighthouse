{
  "stryker-config": {
    "project": "Lighthouse.Backend.csproj",
    "solution": "../Lighthouse.sln",
    "test-projects": [
      "Lighthouse.Backend.Tests.csproj"
    ],
    "mutate": [
      "**/Health/ReadinessState.cs",
      "**/Health/DrainReadinessHealthCheck.cs",
      "**/Health/GracefulShutdownService.cs",
      "**/Services/Implementation/BackgroundServices/Update/UpdateQueueService.cs"
    ],
    "thresholds": {
      "high": 80,
      "low": 70,
      "break": 0
    },
    "coverage-analysis": "perTestInIsolation",
    "test-case-filter": "FullyQualifiedName~ReadinessStateTest|FullyQualifiedName~DrainReadinessHealthCheckTest|FullyQualifiedName~GracefulShutdownServiceTest|FullyQualifiedName~ShutdownIntegrationTest|FullyQualifiedName~UpdateQueueServiceTests",
    "reporters": [
      "progress",
      "html",
      "json",
      "cleartext"
    ],
    "concurrency": 4,
    "additional-timeout": 30000,
    "verbosity": "info"
  }
}
