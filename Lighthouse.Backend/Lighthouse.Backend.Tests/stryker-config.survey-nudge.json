{
  "stryker-config": {
    "project": "Lighthouse.Backend.csproj",
    "solution": "Lighthouse.sln",
    "test-projects": [
      "Lighthouse.Backend.Tests/Lighthouse.Backend.Tests.csproj"
    ],
    "mutate": [
      "**/Services/Implementation/AppSettingService.cs",
      "**/Services/Implementation/Seeding/InstallTimestampSeeder.cs",
      "**/API/SurveyNudgeController.cs"
    ],
    "thresholds": {
      "high": 80,
      "low": 70,
      "break": 0
    },
    "coverage-analysis": "perTestInIsolation",
    "test-case-filter": "FullyQualifiedName~SurveyNudgeSettingsTest|FullyQualifiedName~SurveyNudgeControllerTest|FullyQualifiedName~AppSettingServiceTest|FullyQualifiedName~SystemInfoServiceTest|FullyQualifiedName~SystemInfoControllerTest",
    "reporters": [
      "progress",
      "html",
      "json",
      "cleartext"
    ],
    "concurrency": 4,
    "additional-timeout": 30000,
    "verbosity": "info"
  }
}
