{
  "stryker-config": {
    "project": "Lighthouse.Backend.csproj",
    "solution": "../Lighthouse.sln",
    "test-projects": [
      "Lighthouse.Backend.Tests.csproj"
    ],
    "mutate": [
      "**/Services/Implementation/BlackoutPeriodService.cs",
      "**/Services/Implementation/RecurringBlackoutRuleService.cs",
      "**/Services/Implementation/DomainEvents/BlackoutConfigurationChangedMetricsInvalidationHandler.cs",
      "**/Models/Events/BlackoutConfigurationChanged.cs"
    ],
    "thresholds": {
      "high": 80,
      "low": 70,
      "break": 0
    },
    "coverage-analysis": "perTestInIsolation",
    "test-case-filter": "FullyQualifiedName~BlackoutPeriodServiceTest|FullyQualifiedName~RecurringBlackoutRuleServiceTest|FullyQualifiedName~BlackoutConfigurationChangedMetricsInvalidationHandlerTest|FullyQualifiedName~TeamMetricsServiceTests",
    "reporters": [
      "progress",
      "html",
      "json",
      "cleartext"
    ],
    "concurrency": 4,
    "additional-timeout": 30000,
    "verbosity": "info"
  }
}
