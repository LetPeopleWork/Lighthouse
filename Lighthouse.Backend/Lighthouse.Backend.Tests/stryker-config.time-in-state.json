{
  "stryker-config": {
    "project": "Lighthouse.Backend.csproj",
    "solution": "../Lighthouse.sln",
    "test-projects": [
      "Lighthouse.Backend.Tests.csproj"
    ],
    "mutate": [
      "**/WorkTrackingConnectors/WorkItemStateTransitionMapper.cs",
      "**/Linear/LinearWorkTrackingConnector.cs",
      "**/Linear/LinearResponses.cs",
      "**/Csv/CsvWorkTrackingConnector.cs"
    ],
    "thresholds": {
      "high": 80,
      "low": 70,
      "break": 0
    },
    "coverage-analysis": "perTestInIsolation",
    "test-case-filter": "FullyQualifiedName~WorkItemStateTransitionMapperTest|FullyQualifiedName~LinearWorkTrackingConnector|FullyQualifiedName~CsvWorkTrackingConnectorTest",
    "reporters": [
      "progress",
      "html",
      "json",
      "cleartext"
    ],
    "concurrency": 4,
    "additional-timeout": 30000,
    "verbosity": "info"
  }
}
