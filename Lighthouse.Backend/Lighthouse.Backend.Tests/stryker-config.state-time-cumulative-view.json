{
  "stryker-config": {
    "project": "Lighthouse.Backend.csproj",
    "solution": "../Lighthouse.sln",
    "test-projects": [
      "Lighthouse.Backend.Tests.csproj"
    ],
    "mutate": [
      "**/Services/Implementation/BaseMetricsService.cs",
      "**/Services/Implementation/TeamMetricsService.cs",
      "**/Services/Implementation/PortfolioMetricsService.cs"
    ],
    "thresholds": {
      "high": 80,
      "low": 70,
      "break": 0
    },
    "coverage-analysis": "perTestInIsolation",
    "test-case-filter": "FullyQualifiedName~BaseMetricsServiceTests|FullyQualifiedName~CumulativeStateTimeReadApiIntegrationTest|FullyQualifiedName~CumulativeStateTimePortfolioReadApiIntegrationTest|FullyQualifiedName~TeamMetricsServiceTests|FullyQualifiedName~PortfolioMetricsServiceTests|FullyQualifiedName~CumulativeStateTimeSeamArchUnitTest",
    "reporters": [
      "progress",
      "html",
      "json",
      "cleartext"
    ],
    "concurrency": 4,
    "additional-timeout": 30000,
    "verbosity": "info"
  }
}
