{
  "stryker-config": {
    "project": "Lighthouse.Backend.csproj",
    "solution": "Lighthouse.sln",
    "test-projects": [
      "Lighthouse.Backend.Tests/Lighthouse.Backend.Tests.csproj"
    ],
    "mutate": [
      "**/Services/Implementation/Auth/ApiKeyService.cs",
      "**/Models/Auth/ApiKeyInfo.cs"
    ],
    "thresholds": {
      "high": 80,
      "low": 70,
      "break": 0
    },
    "reporters": [
      "progress",
      "html",
      "json",
      "cleartext"
    ],
    "concurrency": 1,
    "additional-timeout": 30000,
    "verbosity": "info"
  }
}
