{
  "stryker-config": {
    "project": "Lighthouse.Backend.csproj",
    "solution": "Lighthouse.sln",
    "test-projects": [
      "Lighthouse.Backend.Tests/Lighthouse.Backend.Tests.csproj"
    ],
    "mutate": [
      "**/Services/Implementation/OAuth/Providers/AdoOAuthProvider.cs",
      "**/Services/Implementation/WorkTrackingConnectors/AzureDevOps/AzureDevOpsWorkTrackingConnector.cs"
    ],
    "thresholds": {
      "high": 80,
      "low": 70,
      "break": 0
    },
    "coverage-analysis": "perTestInIsolation",
    "test-case-filter": "FullyQualifiedName~AdoOAuthProviderTest|FullyQualifiedName~AzureDevOpsWorkTrackingConnectorTest.ValidateConnection_PatKeyedConnection_DelegatesAuthorizationToResolvedStrategy|FullyQualifiedName~AzureDevOpsWorkTrackingConnectorTest.ValidateConnection_AdoOAuthKeyedConnection_DelegatesAuthorizationToResolvedStrategy",
    "reporters": [
      "progress",
      "html",
      "json",
      "cleartext"
    ],
    "concurrency": 4,
    "additional-timeout": 30000,
    "verbosity": "info"
  }
}
