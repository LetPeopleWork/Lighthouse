      "**/API/DeliveriesController.cs{299..312}",
      "**/Services/Implementation/BackgroundServices/Update/PortfolioUpdater.cs{86..86}",
      "**/Services/Implementation/BackgroundServices/Update/ForecastUpdater.cs{46..46}"
