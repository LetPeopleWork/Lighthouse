{
  "stryker-config": {
    "project": "Lighthouse.Backend.csproj",
    "solution": "../Lighthouse.sln",
    "test-projects": [
      "Lighthouse.Backend.Tests.csproj"
    ],
    "mutate": [
      "**/Configuration/TelemetryConfiguration.cs",
      "**/Startup/LoggingConfigurator.cs",
      "**/Startup/TelemetryConfigurator.cs"
    ],
    "thresholds": {
      "high": 80,
      "low": 70,
      "break": 0
    },
    "coverage-analysis": "perTestInIsolation",
    "test-case-filter": "FullyQualifiedName~MetricsEndpointIntegrationTest|FullyQualifiedName~LoggingConfiguratorTest|FullyQualifiedName~TelemetryConfigurationTest",
    "reporters": [
      "progress",
      "html",
      "json",
      "cleartext"
    ],
    "concurrency": 4,
    "additional-timeout": 30000,
    "verbosity": "info"
  }
}
