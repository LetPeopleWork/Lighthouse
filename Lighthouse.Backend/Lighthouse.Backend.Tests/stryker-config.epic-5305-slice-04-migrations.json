{
  "stryker-config": {
    "project": "Lighthouse.Backend.csproj",
    "solution": "../Lighthouse.sln",
    "test-projects": [
      "Lighthouse.Backend.Tests.csproj"
    ],
    "mutate": [
      "**/Data/DatabaseConfigurator.cs"
    ],
    "thresholds": {
      "high": 80,
      "low": 70,
      "break": 0
    },
    "coverage-analysis": "perTestInIsolation",
    "test-case-filter": "FullyQualifiedName~ConcurrentStartupMigration|FullyQualifiedName~DatabaseManagement|FullyQualifiedName~DatabaseConfigurator|FullyQualifiedName~Seeder|FullyQualifiedName~Seeding",
    "reporters": [
      "progress",
      "html",
      "json",
      "cleartext"
    ],
    "concurrency": 4,
    "additional-timeout": 60000,
    "verbosity": "info"
  }
}
