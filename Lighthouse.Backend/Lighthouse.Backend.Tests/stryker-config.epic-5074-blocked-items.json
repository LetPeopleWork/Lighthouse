{
  "stryker-config": {
    "project": "Lighthouse.Backend.csproj",
    "solution": "../Lighthouse.sln",
    "test-projects": [
      "Lighthouse.Backend.Tests.csproj"
    ],
    "mutate": [
      "**/Services/Implementation/WorkItems/BlockedItemService.cs",
      "**/Services/Implementation/WorkItems/WorkItemService.cs",
      "**/API/DTO/FeatureDto.cs",
      "**/API/DTO/SettingsOwnerDtoBase.cs",
      "**/API/DTO/WorkItemDto.cs",
      "**/API/FeaturesController.cs",
      "**/API/PortfolioController.cs",
      "**/API/TeamController.cs",
      "**/API/TeamMetricsController.cs",
      "**/Models/Feature.cs",
      "**/Models/WorkItem.cs",
      "**/Models/WorkItemBase.cs",
      "**/Models/WorkTrackingSystemOptionsOwner.cs",
      "**/Services/Implementation/WorkItemRules/RuleEvaluator.cs"
    ],
    "thresholds": {
      "high": 80,
      "low": 70,
      "break": 0
    },
    "coverage-analysis": "perTestInIsolation",
    "test-case-filter": "FullyQualifiedName~BlockedItemServiceTest|FullyQualifiedName~BlockedRuleSetMigrationTests|FullyQualifiedName~Slice01RuleBasedBlockedScenarios|FullyQualifiedName~BlockedItemsAcceptanceTest|FullyQualifiedName~BlockedItemSinglePathArchUnitTest|FullyQualifiedName~WorkItemTest|FullyQualifiedName~FeatureTest|FullyQualifiedName~RulesEvaluatorTests|FullyQualifiedName~TeamControllerTest|FullyQualifiedName~PortfolioControllerTest|FullyQualifiedName~WorkItemServiceTest",
    "reporters": [
      "progress",
      "html",
      "json",
      "cleartext"
    ],
    "concurrency": 4,
    "additional-timeout": 30000,
    "verbosity": "info"
  }
}
