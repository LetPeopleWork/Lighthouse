{
  "stryker-config": {
    "project": "Lighthouse.Backend.csproj",
    "solution": "Lighthouse.sln",
    "test-projects": [
      "Lighthouse.Backend.Tests/Lighthouse.Backend.Tests.csproj"
    ],
    "mutate": [
      "**/API/AuthorizationController.cs",
      "**/Models/Authorization/RbacUserSummary.cs",
      "**/Services/Implementation/Authorization/RbacAdministrationService.cs",
      "**/API/ForecastController.cs",
      "**/API/TeamController.cs",
      "**/API/TeamMetricsController.cs",
      "**/API/DTO/BacktestInputDto.cs",
      "**/API/DTO/BacktestResultDto.cs",
      "**/API/DTO/ManualForecastDto.cs",
      "**/API/DTO/TeamSettingDto.cs",
      "**/API/DTO/WhenForecastDto.cs",
      "**/API/Helpers/TeamExtensions.cs",
      "**/Models/Forecast/AggregatedWhenForecast.cs",
      "**/Models/Forecast/WhenForecast.cs",
      "**/Models/Metrics/ThroughputFilterMode.cs",
      "**/Models/Team.cs",
      "**/Services/Implementation/Forecast/ForecastFilterRuleService.cs",
      "**/Services/Implementation/Forecast/ForecastService.cs",
      "**/Services/Implementation/TeamMetricsService.cs",
      "**/Services/Implementation/WorkItemRules/FeatureFieldProvider.cs",
      "**/Services/Implementation/WorkItemRules/RuleEvaluator.cs",
      "**/Services/Implementation/WorkItemRules/WorkItemFieldProvider.cs"
    ],
    "thresholds": {
      "high": 80,
      "low": 70,
      "break": 0
    },
    "reporters": [
      "progress",
      "html",
      "json",
      "cleartext"
    ],
    "concurrency": 4,
    "additional-timeout": 30000,
    "verbosity": "info"
  }
}
