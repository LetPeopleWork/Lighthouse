{
  "stryker-config": {
    "project": "Lighthouse.Backend.csproj",
    "solution": "../Lighthouse.sln",
    "test-projects": [
      "Lighthouse.Backend.Tests.csproj"
    ],
    "mutate": [
      "**/Services/Implementation/BaseMetricsService.cs",
      "**/Services/Implementation/TeamMetricsService.cs",
      "**/Services/Implementation/PortfolioMetricsService.cs",
      "**/API/TeamMetricsController.cs",
      "**/API/PortfolioMetricsController.cs",
      "**/Models/Metrics/InfoWidgetDtos.cs"
    ],
    "thresholds": {
      "high": 80,
      "low": 70,
      "break": 0
    },
    "coverage-analysis": "perTestInIsolation",
    "test-case-filter": "FullyQualifiedName~FlowEfficiencyReadApiIntegrationTest|FullyQualifiedName~FlowEfficiencyPortfolioReadApiIntegrationTest|FullyQualifiedName~BaseMetricsServiceTests|FullyQualifiedName~PortfolioMetricsServiceTests|FullyQualifiedName~FlowEfficiencySeamArchUnitTest",
    "reporters": [
      "progress",
      "html",
      "json",
      "cleartext"
    ],
    "concurrency": 4,
    "additional-timeout": 30000,
    "verbosity": "info"
  }
}
