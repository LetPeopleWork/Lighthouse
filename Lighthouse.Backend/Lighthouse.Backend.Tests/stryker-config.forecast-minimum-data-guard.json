{
  "stryker-config": {
    "project": "Lighthouse.Backend.csproj",
    "solution": "../Lighthouse.sln",
    "test-projects": [
      "Lighthouse.Backend.Tests.csproj"
    ],
    "mutate": [
      "**/Services/Implementation/Forecast/ForecastDataSufficiencyPolicy.cs",
      "**/Models/Metrics/RunChartData.cs",
      "**/Models/Forecast/AggregatedWhenForecast.cs"
    ],
    "thresholds": {
      "high": 80,
      "low": 70,
      "break": 0
    },
    "coverage-analysis": "perTestInIsolation",
    "test-case-filter": "FullyQualifiedName~TeamMetricsServiceTests|FullyQualifiedName~ForecastServiceTest|FullyQualifiedName~ForecastControllerTest|FullyQualifiedName~DeliveryWithLikelihoodDtoTest|FullyQualifiedName~AggregatedWhenForecastTest|FullyQualifiedName~ForecastFilterTeamForecastIntegrationTest|FullyQualifiedName~PortfolioMetricsServiceTests",
    "reporters": [
      "progress",
      "html",
      "json",
      "cleartext"
    ],
    "concurrency": 4,
    "additional-timeout": 30000,
    "verbosity": "info"
  }
}
