#!/usr/bin/env bash
set -euo pipefail

# Check if gitleaks is installed
if ! command -v gitleaks &>/dev/null; then
  echo "❌ gitleaks is required but not installed."
  echo ""
  echo "Install it:"
  echo "  macOS/Linux: brew install gitleaks"
  echo "  Windows:     winget install gitleaks"
  echo ""
  echo "More info:"
  echo "  https://github.com/gitleaks/gitleaks"
  echo ""
  echo "Commit blocked."
  exit 1
fi

echo "🔍 Scanning staged files for secrets..."

if ! gitleaks protect --staged --redact --no-banner; then
  echo ""
  echo "❌ Potential secrets detected in staged files."
  echo ""
  echo "To inspect findings in detail, run:"
  echo ""
  echo "  gitleaks protect --staged --verbose --no-banner"
  echo ""
  echo "Or generate a JSON report:"
  echo ""
  echo "  gitleaks protect \\"
  echo "    --staged \\"
  echo "    --report-format json \\"
  echo "    --report-path gitleaks-report.json"
  echo ""
  echo "Then inspect:"
  echo ""
  echo "  cat gitleaks-report.json | jq"
  echo ""
  echo "If this is a false positive, allowlist it in .gitleaks.toml"
  exit 1
fi

echo "✅ No secrets detected."