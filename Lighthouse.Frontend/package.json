{
	"name": "lighthouse.frontend",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "cross-env VITE_API_BASE_URL=http://localhost:5169/api vite",
		"build": "tsc -b && vite build --outDir ../Lighthouse.Backend/Lighthouse.Backend/wwwroot",
		"build-docker": "tsc -b && vite build --outDir ./dist",
		"prebuild": "pnpm biome check --write ./src",
		"preview": "vite preview",
		"test": "vitest run --reporter=default",
		"sonarreport": "vitest run --coverage",
		"tauri": "tauri",
		"update-sidecar": "dotnet publish -c Release -r linux-x64 --self-contained -p:PublishSingleFile=true -p:IncludeNativeLibrariesForSelfExtract=true -o ../Lighthouse.Backend/Lighthouse.Backend/publish/linux-x64 ../Lighthouse.Backend/Lighthouse.Backend && mkdir -p src-tauri/binaries && mkdir -p src-tauri/resources && cp ../Lighthouse.Backend/Lighthouse.Backend/publish/linux-x64/Lighthouse src-tauri/binaries/Lighthouse.Backend-x86_64-unknown-linux-gnu && chmod +x src-tauri/binaries/Lighthouse.Backend-x86_64-unknown-linux-gnu && cp -r ../Lighthouse.Backend/Lighthouse.Backend/publish/linux-x64/. src-tauri/resources/ && rm -f src-tauri/resources/Lighthouse"
	},
	"dependencies": {
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@melloware/react-logviewer": "^6.5.1",
		"@microsoft/signalr": "^10.0.0",
		"@mui/icons-material": "^7.3.9",
		"@mui/lab": "^7.0.0",
		"@mui/material": "^7.3.9",
		"@mui/system": "^7.3.9",
		"@mui/x-charts": "8.11.3",
		"@mui/x-data-grid": "^8.28.2",
		"@mui/x-date-pickers": "8.11.3",
		"@tanstack/react-query": "^5.96.1",
		"@tauri-apps/api": "^2",
		"axios": "^1.14.0",
		"camelcase-keys": "^10.0.2",
		"class-transformer": "^0.5.1",
		"date-fns": "^4.1.0",
		"dayjs": "^1.11.20",
		"lodash.debounce": "^4.0.8",
		"lorem-ipsum": "^2.0.8",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.14.0",
		"reflect-metadata": "^0.2.2",
		"remark-gfm": "^4.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@tauri-apps/cli": "^2",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/date-fns": "^2.6.3",
		"@types/lodash.debounce": "^4.0.9",
		"@types/node": "^25.5.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.0",
		"@vitest/coverage-v8": "^4.1.0",
		"@vitest/spy": "4.1.2",
		"cross-env": "^10.1.0",
		"jsdom": "^29.0.1",
		"parse5": "^8.0.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.5",
		"vitest": "^4.1.0",
		"vitest-sonar-reporter": "^3.0.0"
	},
	"pnpm": {
		"overrides": {
			"immutable": ">=5.1.5",
			"picomatch": "^4.0.4",
			"yaml": "^1.10.3"
		},
		"ignoredBuiltDependencies": [
			"esbuild"
		]
	}
}
