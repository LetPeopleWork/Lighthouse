{
	"identifier": "default",
	"description": "Default capability for the Lighthouse standalone app",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"shell:default",
		{
			"identifier": "shell:allow-execute",
			"allow": [{ "name": "binaries/Lighthouse.Backend", "sidecar": true }]
		},
		{
			"identifier": "shell:allow-spawn",
			"allow": [{ "name": "binaries/Lighthouse.Backend", "sidecar": true }]
		}
	]
}
