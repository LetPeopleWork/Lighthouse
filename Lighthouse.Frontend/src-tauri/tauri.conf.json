{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Lighthouse",
	"version": "0.1.0",
	"identifier": "work.letpeople.lighthouse",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:5173",
		"beforeBuildCommand": "pnpm build-docker",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Lighthouse",
				"width": 1200,
				"height": 800,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.ico",
			"icons/icon.png"
		],
		"createUpdaterArtifacts": true,
		"resources": ["resources/**/*"],
		"externalBin": ["binaries/Lighthouse.Backend"],
		"macOS": {
			"entitlements": "entitlements.plist",
			"minimumSystemVersion": "10.15",
			"hardenedRuntime": true
		}
	},
	"plugins": {
		"updater": {
			"endpoints": [
				"https://github.com/LetPeopleWork/Lighthouse/releases/latest/download/tauri-update.json"
			],
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJFNzJFODUxMDkxNjQzQQpSV1E2WkpFUWhTN25Bdm5PYzlPQnR0Rzc5QWdjZTU2T2xyNllIUnMwdEczOWNaeXBiYXRXcC9QNQo="
		}
	}
}
