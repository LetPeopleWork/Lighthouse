{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
	"productName": "Lighthouse",
	"version": "0.1.0",
	"identifier": "io.letPeopleWork.lighthouse",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:5173",
		"beforeBuildCommand": "pnpm build-docker",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Lighthouse",
				"width": 1200,
				"height": 800,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.ico",
			"icons/icon.png"
		],
		"resources": ["resources/**/*"],
		"externalBin": ["binaries/Lighthouse.Backend"],
		"macOS": {
			"entitlements": "entitlements.plist",
			"minimumSystemVersion": "10.15"
		}
	},
	"plugins": {}
}
