#!/usr/bin/env bash
# Dev-mode sidecar wrapper for the Lighthouse .NET backend.
# In production builds, this script is replaced by the published .NET binary.
#
# Resolves the backend project relative to this script's location:
#   src-tauri/binaries/ -> ../../Lighthouse.Backend/Lighthouse.Backend/

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
BACKEND_PROJECT="$SCRIPT_DIR/../../../../Lighthouse.Backend/Lighthouse.Backend"

export ASPNETCORE_ENVIRONMENT=Development

exec dotnet run --project "$BACKEND_PROJECT" -- "$@"
